# ═══════════════════════════════════════════════════════════════
#  Snowflake connection (used by ingestion, chatbot, streamlit)
# ═══════════════════════════════════════════════════════════════
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=INSURANCE_SVC
SNOWFLAKE_ROLE=INSURANCE_ENGINEER
SNOWFLAKE_WAREHOUSE=INSURANCE_WH
SNOWFLAKE_DATABASE=INSURANCE_PLATFORM

# Password auth (dashboard / chatbot read paths)
SNOWFLAKE_PASSWORD=changeme

# Key-pair auth (REQUIRED for Snowpipe Streaming ingest)
# Generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -nocrypt -out rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PATH=./secrets/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ═══════════════════════════════════════════════════════════════
#  Kafka
# ═══════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_POLICIES=insurance.policies.raw
KAFKA_TOPIC_CLAIMS=insurance.claims.raw
KAFKA_CONSUMER_GROUP=snowpipe-streaming-ingest

# ═══════════════════════════════════════════════════════════════
#  Cortex
# ═══════════════════════════════════════════════════════════════
# Default LLM for COMPLETE-based tasks (header mapping, enrichment, NL→SQL)
CORTEX_MODEL=claude-3-5-sonnet
# Cheaper model for high-volume row-level classification
CORTEX_CLASSIFY_MODEL=mistral-large2

# ═══════════════════════════════════════════════════════════════
#  Snowpipe Streaming target
# ═══════════════════════════════════════════════════════════════
SNOWPIPE_CHANNEL_PREFIX=broker-ingest
SNOWPIPE_RAW_SCHEMA=RAW
